{
  "name": "robotics-simulation-infra",
  "dockerComposeFile": "../compose.yaml",
  "service": "simulation",
  "workspaceFolder": "/workspaces/robotics-simulation-infra",
  "overrideCommand": true,
  "features": {
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1.9.1": {}
  },
  "containerEnv": {
    "PYTHONUNBUFFERED": "1"
  },
  "postCreateCommand": "python3 -m venv .venv && . .venv/bin/activate && python -m pip install --upgrade pip && python -m pip install -r requirements-dev.txt",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-azuretools.vscode-docker",
        "ms-python.python",
        "ms-python.ruff"
      ]
    }
  },
  "remoteUser": "root"
}
