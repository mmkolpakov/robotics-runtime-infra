{
  "name": "robotics-simulation-infra",
  "image": "ghcr.io/mmkolpakov/droning-simulation-infra:0.4.0",
  "overrideCommand": true,
  "remoteUser": "ubuntu",
  "runArgs": [
    "--init"
  ],
  "containerEnv": {
    "GZ_PARTITION": "robotics-devcontainer",
    "LIBGL_ALWAYS_SOFTWARE": "1",
    "ROS_AUTOMATIC_DISCOVERY_RANGE": "SUBNET"
  }
}
