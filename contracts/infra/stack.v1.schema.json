{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/infra/stack.v1.schema.json",
  "title": "SimulationStack",
  "type": "object",
  "required": [
    "stack_id",
    "version_date",
    "target_host",
    "images",
    "packages",
    "smoke_expectations"
  ],
  "properties": {
    "stack_id": {
      "type": "string",
      "pattern": "^[a-z0-9_]+$"
    },
    "version_date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "target_host": {
      "type": "object",
      "required": [
        "os",
        "container_runtime",
        "gpu_required"
      ],
      "properties": {
        "os": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "container_runtime": { "type": "string" },
        "gpu_required": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "images": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": [
          "image",
          "role",
          "source"
        ],
        "properties": {
          "image": { "type": "string" },
          "role": { "type": "string" },
          "source": { "type": "string" },
          "local_tag": { "type": "string" },
          "observed_digest": { "type": "string" },
          "observed_last_updated": { "type": "string" },
          "release_gate": { "type": "boolean" },
          "notes": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      }
    },
    "packages": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": [
          "package",
          "version",
          "source"
        ],
        "properties": {
          "package": { "type": "string" },
          "version": { "type": "string" },
          "source": { "type": "string" },
          "observed_at": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "notes": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      }
    },
    "source_refs": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": [
          "repository",
          "ref",
          "sha"
        ],
        "properties": {
          "repository": { "type": "string" },
          "ref": { "type": "string" },
          "sha": {
            "type": "string",
            "pattern": "^[a-f0-9]{40}$"
          }
        },
        "additionalProperties": false
      }
    },
    "smoke_expectations": {
      "type": "object",
      "required": [
        "profiles"
      ],
      "properties": {
        "profiles": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": [
              "service",
              "release_gate"
            ],
            "properties": {
              "service": { "type": "string" },
              "compose_profile": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "release_gate": { "type": "boolean" },
              "ros_packages": {
                "type": "array",
                "items": { "type": "string" }
              },
              "python_imports": {
                "type": "array",
                "items": { "type": "string" }
              },
              "commands": {
                "type": "array",
                "items": { "type": "string" }
              },
              "notes": {
                "type": "array",
                "items": { "type": "string" }
              }
            },
            "additionalProperties": false
          },
          "minProperties": 1
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
