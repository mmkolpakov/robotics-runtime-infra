{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/infra/ros-graph-contract.v1.schema.json",
  "title": "RosGraphContractV1",
  "type": "object",
  "required": [
    "schema_version",
    "graph_ready_timeout_sec",
    "require_clock",
    "topics"
  ],
  "properties": {
    "schema_version": { "const": "ros-graph-contract.v1" },
    "graph_ready_timeout_sec": {
      "type": "integer",
      "minimum": 1,
      "maximum": 600
    },
    "require_clock": { "type": "boolean" },
    "topics": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "type", "publisher_match", "subscriber_match"],
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string" },
          "publisher_match": {
            "type": "object",
            "required": ["min_count", "timeout_sec"],
            "properties": {
              "min_count": { "type": "integer", "minimum": 0 },
              "timeout_sec": { "type": "integer", "minimum": 1, "maximum": 600 }
            },
            "additionalProperties": false
          },
          "subscriber_match": {
            "type": "object",
            "required": ["min_count", "timeout_sec"],
            "properties": {
              "min_count": { "type": "integer", "minimum": 0 },
              "timeout_sec": { "type": "integer", "minimum": 1, "maximum": 600 }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    },
    "services": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type", "ready_timeout_sec"],
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string" },
          "ready_timeout_sec": { "type": "integer", "minimum": 1, "maximum": 600 }
        },
        "additionalProperties": false
      }
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type", "ready_timeout_sec"],
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string" },
          "ready_timeout_sec": { "type": "integer", "minimum": 1, "maximum": 600 }
        },
        "additionalProperties": false
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "require_clock": { "const": true } } },
      "then": {
        "properties": {
          "topics": {
            "contains": {
              "type": "object",
              "required": ["name"],
              "properties": { "name": { "const": "/clock" } }
            }
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
