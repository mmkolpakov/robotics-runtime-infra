{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/infra/evidence-manifest.schema.json",
  "title": "EvidenceManifest",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "profile_id",
    "created_at",
    "result",
    "runtime",
    "artifacts"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.1"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "profile_id": {
      "type": "string",
      "pattern": "^[a-z0-9_]+$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "result": {
      "type": "string",
      "enum": [
        "pass",
        "fail",
        "blocked",
        "not_run"
      ]
    },
    "runtime": {
      "type": "object",
      "required": [
        "os",
        "container_runtime",
        "image"
      ],
      "properties": {
        "os": { "type": "string" },
        "container_runtime": { "type": "string" },
        "image": { "type": "string" },
        "image_digest": {
          "type": [
            "string",
            "null"
          ]
        },
        "source_ref": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "result"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$"
          },
          "result": {
            "type": "string",
            "enum": [
              "pass",
              "fail",
              "blocked",
              "not_run"
            ]
          },
          "duration_s": {
            "type": [
              "number",
              "null"
            ],
            "minimum": 0
          },
          "log": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "additionalProperties": false
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": {
        "type": [
          "number",
          "string",
          "boolean",
          "null"
        ]
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "kind",
          "path"
        ],
        "properties": {
          "kind": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$"
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "media_type": {
            "type": [
              "string",
              "null"
            ]
          },
          "required": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      },
      "minItems": 1
    }
  },
  "additionalProperties": false
}
