{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/infra/runtime-profiles.schema.json",
  "title": "RuntimeProfiles",
  "type": "object",
  "required": [
    "matrix_id",
    "version_date",
    "policy",
    "profiles",
    "decision_points",
    "extension_contracts"
  ],
  "properties": {
    "matrix_id": {
      "type": "string",
      "pattern": "^[a-z0-9_]+$"
    },
    "version_date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "policy": {
      "type": "object",
      "required": [
        "public_scope",
        "product_logic",
        "version_line",
        "default_gpu_required"
      ],
      "properties": {
        "public_scope": { "type": "string" },
        "product_logic": { "type": "string" },
        "version_line": { "type": "string" },
        "default_gpu_required": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "profiles": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": [
          "status",
          "purpose",
          "release_gate",
          "compose_profiles",
          "host",
          "capabilities",
          "checks",
          "artifacts"
        ],
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "ready",
              "partial",
              "optional",
              "external"
            ]
          },
          "purpose": { "type": "string" },
          "release_gate": { "type": "boolean" },
          "compose_profiles": {
            "type": "array",
            "items": { "type": "string" }
          },
          "host": {
            "type": "object",
            "required": [
              "os",
              "container_runtime",
              "gpu_required"
            ],
            "properties": {
              "os": {
                "type": "array",
                "items": { "type": "string" },
                "minItems": 1
              },
              "container_runtime": { "type": "string" },
              "gpu_required": { "type": "boolean" }
            },
            "additionalProperties": false
          },
          "capabilities": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "id",
                "category",
                "components"
              ],
              "properties": {
                "id": {
                  "type": "string",
                  "pattern": "^[a-z0-9_]+$"
                },
                "category": { "type": "string" },
                "components": {
                  "type": "array",
                  "items": { "type": "string" },
                  "minItems": 1
                },
                "notes": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              },
              "additionalProperties": false
            },
            "minItems": 1
          },
          "checks": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "id",
                "command",
                "required"
              ],
              "properties": {
                "id": {
                  "type": "string",
                  "pattern": "^[a-z0-9_]+$"
                },
                "command": { "type": "string" },
                "required": { "type": "boolean" },
                "notes": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              },
              "additionalProperties": false
            }
          },
          "artifacts": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      }
    },
    "decision_points": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "default",
          "alternatives",
          "rationale"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$"
          },
          "default": { "type": "string" },
          "rationale": { "type": "string" },
          "alternatives": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "id",
                "status",
                "compose_profile",
                "release_gate",
                "gpu_required"
              ],
              "properties": {
                "id": {
                  "type": "string",
                  "pattern": "^[a-z0-9_]+$"
                },
                "status": {
                  "type": "string",
                  "enum": [
                    "ready",
                    "partial",
                    "optional",
                    "external"
                  ]
                },
                "compose_profile": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "release_gate": { "type": "boolean" },
                "gpu_required": { "type": "boolean" },
                "notes": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              },
              "additionalProperties": false
            },
            "minItems": 1
          }
        },
        "additionalProperties": false
      },
      "minItems": 1
    },
    "extension_contracts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "boundary",
          "owner"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$"
          },
          "boundary": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          },
          "owner": { "type": "string" },
          "notes": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      },
      "minItems": 1
    }
  },
  "additionalProperties": false
}
