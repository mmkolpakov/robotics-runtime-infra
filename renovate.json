{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests"
  ],
  "dependencyDashboard": true,
  "minimumReleaseAge": "3 days",
  "packageRules": [
    {
      "description": "Keep runtime and CI dependencies reproducible",
      "matchManagers": [
        "docker-compose",
        "dockerfile",
        "github-actions"
      ],
      "rangeStrategy": "pin"
    }
  ]
}
