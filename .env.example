# Local Compose and Makefile defaults.
# Copy to .env and adjust locally. The .env file is ignored by Git.

COMPOSE_PROJECT_NAME=robotics-simulation-infra

IMAGE_TAG=robotics/ros-jazzy-simulation:2026-07-05
DEV_SERVICE=simulation-dev

# Allocate per run via: make RUN_ID=<id> allocate-run
# ROS_DOMAIN_ID=
RMW_IMPLEMENTATION=rmw_fastrtps_cpp

DOCKER_BUILD_NETWORK=host
DOCKER_RUN_NETWORK=bridge
GPU_DEVICE_IDS=0

PRODUCT_CONFIG_DIR=/workspace/product/config
