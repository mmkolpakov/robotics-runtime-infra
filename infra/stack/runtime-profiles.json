{
  "matrix_id": "robotics_simulation_runtime_profiles",
  "version_date": "2026-07-06",
  "policy": {
    "public_scope": "Reusable infrastructure for robotics simulation, runtime checks, data capture, and integration boundaries.",
    "product_logic": "out_of_scope",
    "version_line": "ubuntu_24_04_ros2_jazzy_gazebo_harmonic",
    "default_gpu_required": false
  },
  "profiles": {
    "core_simulation": {
      "status": "ready",
      "purpose": "Base containerized simulation runtime for local and CI checks.",
      "release_gate": true,
      "compose_profiles": [],
      "host": {
        "os": [
          "windows_11_wsl2",
          "linux"
        ],
        "container_runtime": "docker",
        "gpu_required": false
      },
      "capabilities": [
        {
          "id": "ros2_runtime",
          "category": "middleware",
          "components": [
            "ubuntu_24_04_noble",
            "ros2_jazzy"
