          "id": "build_image",
          "command": "make compose-build",
          "required": true
        },
        {
          "id": "smoke_image",
          "command": "make compose-smoke",
          "required": true
        },
        {
          "id": "integration_smoke",
          "command": "make integration-smoke",
          "required": true
        }
      ],
      "artifacts": [
        "artifacts/reports/compose-smoke.txt",
        "artifacts/reports/integration-smoke.txt",
        "artifacts/reports/docker-image-inspect.json"
