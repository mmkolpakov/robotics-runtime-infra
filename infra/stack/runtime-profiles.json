  "decision_points": [
    {
      "id": "compute_acceleration",
      "default": "cpu_container_runtime",
      "rationale": "The base release path must run on ordinary Linux or Windows WSL2 hosts without a dedicated GPU.",
      "alternatives": [
        {
          "id": "cpu_container_runtime",
          "status": "ready",
          "compose_profile": null,
          "release_gate": true,
          "gpu_required": false
        },
        {
          "id": "nvidia_container_runtime",
          "status": "optional",
          "compose_profile": "nvidia",
          "release_gate": false,
          "gpu_required": true,
          "notes": [
            "Validated by make compose-gpu-smoke only on hosts with NVIDIA container runtime."
          ]
        },
        {
          "id": "nvidia_inference_runtime",
          "status": "optional",
          "compose_profile": "inference",
          "release_gate": false,
          "gpu_required": true,
          "notes": [
            "Validated by make compose-accelerated-inference-smoke on hosts with NVIDIA container runtime."
          ]
        }
      ]
    },
    {
      "id": "local_rendering",
      "default": "headless",
      "rationale": "Headless CI and WSL2 smoke checks are the default; local rendering is a host capability, not a product assumption.",
      "alternatives": [
        {
          "id": "headless",
          "status": "ready",
          "compose_profile": null,
          "release_gate": true,
          "gpu_required": false
        },
        {
          "id": "direct_render_device",
          "status": "optional",
          "compose_profile": "render",
          "release_gate": false,
          "gpu_required": false,
          "notes": [
            "Uses /dev/dri when the host exposes it, including Intel or AMD integrated graphics on Linux/WSL2."
          ]
        }
      ]
    },
    {
      "id": "ros_gazebo_line",
      "default": "ubuntu_24_04_ros2_jazzy_gazebo_harmonic",
      "rationale": "This is the recommended ROS 2 Jazzy line for July 2026 and avoids non-default ROS/Gazebo pairings.",
      "alternatives": [
        {
          "id": "ubuntu_24_04_ros2_jazzy_gazebo_harmonic",
          "status": "ready",
          "compose_profile": null,
          "release_gate": true,
          "gpu_required": false
        },
        {
          "id": "external_ros_line",
          "status": "external",
          "compose_profile": null,
          "release_gate": false,
          "gpu_required": false,
          "notes": [
            "External projects may adapt older ROS 2 lines above this repository, but this repository does not carry them as a default."
          ]
        }
      ]
    },
    {
      "id": "autopilot_bridge",
      "default": "mavlink_mavros",
      "rationale": "MAVLink/MAVROS is the release-gated bridge currently present in the neutral image.",
      "alternatives": [
        {
          "id": "mavlink_mavros",
          "status": "partial",
          "compose_profile": "autopilot",
          "release_gate": true,
          "gpu_required": false
        },
        {
          "id": "dds_bridge",
          "status": "optional",
          "compose_profile": "dds",
          "release_gate": false,
          "gpu_required": false,
          "notes": [
            "Available as a separate neutral bridge profile; message packages and topic contracts remain owned by upper projects."
          ]
        }
      ]
    },
    {
      "id": "sitl_runtime_family",
      "default": "ardupilot_base_probe",
      "rationale": "The release gate checks a stable base SITL environment; more specific simulator runtimes remain explicit optional profiles until their scenario contracts are owned by upper projects.",
      "alternatives": [
        {
          "id": "ardupilot_base_probe",
          "status": "partial",
          "compose_profile": "ardupilot",
          "release_gate": true,
          "gpu_required": false
        },
        {
          "id": "px4_sitl_runtime",
          "status": "optional",
          "compose_profile": "px4",
          "release_gate": false,
          "gpu_required": false,
          "notes": [
            "The currently selected image tag is kept outside release gates because it is an alpha line."
          ]
        }
      ]
    },
    {
      "id": "dds_bridge_runtime",
      "default": "micro_xrce_dds_agent",
      "rationale": "DDS bridge runtime is useful for autopilot integrations, but it must remain optional until an upper stack owns message packages and topics.",
      "alternatives": [
        {
          "id": "micro_xrce_dds_agent",
          "status": "optional",
          "compose_profile": "dds",
          "release_gate": false,
          "gpu_required": false
        },
        {
          "id": "external_message_packages",
          "status": "external",
          "compose_profile": null,
          "release_gate": false,
          "gpu_required": false,
          "notes": [
            "Message packages are intentionally owned by upper projects."
          ]
        }
      ]
    },
    {
      "id": "distributed_comms_bridge",
      "default": "local_dds",
      "rationale": "Local DDS remains the default; distributed bridge runtime is optional for larger or remote simulations.",
      "alternatives": [
        {
          "id": "local_dds",
          "status": "ready",
          "compose_profile": null,
          "release_gate": true,
          "gpu_required": false
        },
        {
          "id": "zenoh_ros2_bridge",
          "status": "optional",
          "compose_profile": "comms",
          "release_gate": false,
          "gpu_required": false
        }
      ]
    },
    {
      "id": "media_pipeline_runtime",
      "default": "ros_image_contract",
      "rationale": "ROS image topics are enough for the default gate; media streaming is optional infrastructure for camera-heavy scenarios.",
      "alternatives": [
        {
          "id": "ros_image_contract",
          "status": "partial",
          "compose_profile": null,
          "release_gate": true,
          "gpu_required": false
        },
        {
          "id": "gstreamer_pipeline",
          "status": "optional",
          "compose_profile": "media",
          "release_gate": false,
          "gpu_required": false
        }
      ]
    },
    {
      "id": "perception_provider",
      "default": "ros_image_contract",
      "rationale": "The infrastructure owns transport and contracts, while model selection and model quality belong to upper projects.",
      "alternatives": [
        {
          "id": "ros_image_contract",
          "status": "partial",
          "compose_profile": null,
          "release_gate": true,
          "gpu_required": false
        },
        {
          "id": "accelerated_inference_provider",
          "status": "optional",
          "compose_profile": "inference",
          "release_gate": false,
          "gpu_required": true,
          "notes": [
            "The repository validates provider runtime availability, not application model correctness."
          ]
        }
      ]
    },
    {
      "id": "diagnostics_runtime",
      "default": "machine_readable_reports",
      "rationale": "CI must rely on machine-readable reports; GUI diagnostics are useful locally but not a release gate.",
      "alternatives": [
        {
          "id": "machine_readable_reports",
          "status": "ready",
          "compose_profile": null,
          "release_gate": true,
          "gpu_required": false
        },
        {
          "id": "plotjuggler_runtime",
          "status": "optional",
          "compose_profile": "diagnostics",
          "release_gate": false,
          "gpu_required": false
        },
        {
          "id": "ground_control_station",
          "status": "external",
          "compose_profile": null,
          "release_gate": false,
          "gpu_required": false,
          "notes": [
            "Ground control UI is kept outside CI and can be supplied by the operator workstation or an upper project."
          ]
        }
      ]
    },
    {
      "id": "edge_deployment",
      "default": "amd64_wsl2_linux",
      "rationale": "The default infrastructure target is amd64 Linux/WSL2; ARM64 edge deployment requires a separate optional lane.",
      "alternatives": [
        {
          "id": "amd64_wsl2_linux",
          "status": "ready",
          "compose_profile": null,
          "release_gate": true,
          "gpu_required": false
        },
        {
          "id": "jetson_arm64",
          "status": "optional",
          "compose_profile": "edge",
          "release_gate": false,
          "gpu_required": true
        }
      ]
    }
  ],
