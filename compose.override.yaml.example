---
services:
  simulation:
    environment:
      ROS_DOMAIN_ID: "${ROS_DOMAIN_ID:?ROS_DOMAIN_ID must be allocated}"
      RMW_IMPLEMENTATION: "${RMW_IMPLEMENTATION:-rmw_fastrtps_cpp}"
      PRODUCT_CONFIG_DIR: "${PRODUCT_CONFIG_DIR:-/workspace/product/config}"
    volumes:
      - ./product:/workspace/product:rw
      - ./runs/${RUN_ID:?RUN_ID required}/data:/workspace/data:rw

  simulation-dev:
    environment:
      ROS_DOMAIN_ID: "${ROS_DOMAIN_ID:?ROS_DOMAIN_ID must be allocated}"
      RMW_IMPLEMENTATION: "${RMW_IMPLEMENTATION:-rmw_fastrtps_cpp}"
      PRODUCT_CONFIG_DIR: "${PRODUCT_CONFIG_DIR:-/workspace/product/config}"
    volumes:
      - ./product:/workspace/product:rw
      - ./runs/${RUN_ID:?RUN_ID required}/data:/workspace/data:rw

  media-runtime:
    environment:
      ROS_DOMAIN_ID: "${ROS_DOMAIN_ID:?ROS_DOMAIN_ID must be allocated}"
    volumes:
      - ./runs/${RUN_ID:?RUN_ID required}/data:/workspace/data:rw
